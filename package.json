{
  "name": "sweepur",
  "version": "0.1.0",
  "description": "A small OpenTUI dashboard for sweeping local ports and Docker containers.",
  "homepage": "https://github.com/jacksonwyt/sweepur#readme",
  "bugs": {
    "url": "https://github.com/jacksonwyt/sweepur/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jacksonwyt/sweepur.git"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "sweepur": "./bin/sweepur.js"
  },
  "files": [
    "bin",
    "src",
    "README.md"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "check": "bun test && bun run typecheck",
    "prepublishOnly": "bun run check"
  },
  "keywords": [
    "tui",
    "cli",
    "opentui",
    "docker",
    "ports"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.6",
  "dependencies": {
    "@opentui/core": "0.1.87"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.2"
  }
}
